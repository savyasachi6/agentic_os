# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agent_os
POSTGRES_USER=agent
POSTGRES_PASSWORD=password

# LLM & Embeddings
LLM_MODEL=llama3.2
EMBED_MODEL=nomic-embed-text
OLLAMA_HOST=http://host.docker.internal:11434

# Security
JWT_SECRET=generate-a-safe-secret-key-here
TLS_ENABLED=false
CERTS_DIR=certs

# Sandbox
SANDBOX_BASE_PORT=9100
TOOLS_API_URL=http://tools-api:9100
