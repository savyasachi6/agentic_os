# === Database ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_os
POSTGRES_USER=agent
POSTGRES_PASSWORD=password

# === LLM ===
LLM_MODEL=llama3.2
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# === Agent ===
SKILLS_DIR=skills
CHUNK_MIN_TOKENS=500
CHUNK_MAX_TOKENS=800
RETRIEVAL_TOP_K=4
REACT_MAX_ITERATIONS=10

# === Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# === Sandbox Workers ===
SANDBOX_TIMEOUT=300
SANDBOX_MAX_MEMORY_MB=512
SANDBOX_MAX_WORKERS=4
SANDBOX_BASE_PORT=9100

# === Lane Queue ===
USE_QUEUE=true
QUEUE_POLL_INTERVAL=0.5
QUEUE_MAX_RETRIES=3
QUEUE_TOOL_TIMEOUT=300
