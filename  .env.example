# Agentic OS Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agent_os
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_os_pw
POSTGRES_POOL_SIZE=20

# Redis
REDIS__HOST=redis
REDIS__PASSWORD=redis_safe_pw
REDIS_PORT=6379

# Ollama / Local LLM
OLLAMA_MODEL=gemma3:4b
OLLAMA_MODEL_NANO=qwen2.5:0.5b-instruct-q4_K_M
OLLAMA_MODEL_FAST=qwen2.5:1.5b-instruct-q4_K_M
OLLAMA_MODEL_FULL=gemma3:4b
EMBED_MODEL=mxbai-embed-large
OLLAMA_HOST=http://host.docker.internal:11434
USE_MOCK_LLM=false

# Security
JWT_SECRET=generate-a-safe-secret-key-here
TLS_ENABLED=false
CERTS_DIR=certs

# Sandbox
SANDBOX_BASE_PORT=9100
TOOLS_API_URL=http://tools-api:9100

# OpenAI / OpenRouter (Cloud)
# Register at openrouter.ai to get a key
LLM__OPENAI_API_KEY=YOUR_OPENROUTER_API_KEY
LLM__OPENAI_API_BASE=https://openrouter.ai/api/v1
LLM__OPENAI_MODEL=google/gemini-2.0-flash-001

# RL Router
RL_ROUTER_URL=http://rl-router:8100
RL_ROUTER_TIMEOUT=20.0
DATABASE_URL=postgresql://agent:agent_os_pw@postgres:5432/agent_os

# Operational Mode
ONLINE=false
