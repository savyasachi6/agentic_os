{
    "include": [
        "."
    ],
    "exclude": [
        "**/node_modules",
        "**/__pycache__",
        "dist",
        ".git",
        ".venv"
    ],
    "reportMissingImports": "warning",
    "reportMissingTypeStubs": false,
    "pythonVersion": "3.12",
    "typeCheckingMode": "basic",
    "reportMissingModuleSource": "none",
    "reportAttributeAccessIssue": "warning",
    "pythonPlatform": "Windows",
    "venvPath": ".",
    "venv": ".venv",
    "extraPaths": [
        "."
    ]
}