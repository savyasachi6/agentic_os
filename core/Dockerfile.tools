FROM python:3.11-slim

WORKDIR /sandbox

# Install basic system utilities that might be useful for tools, 
# but deliberately exclude/restrict compilers or excessive tools.
RUN apt-get update && apt-get install -y \
    curl \
    iproute2 \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user to run the sandbox
RUN useradd -m -s /bin/bash sandboxuser
RUN chown -R sandboxuser:sandboxuser /sandbox

# Install Python dependencies needed by the worker
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt fastapi uvicorn pydantic

# Copy only the sandbox code
COPY agent_sandbox/ sandbox/

# Switch to the non-root user
USER sandboxuser

# In Docker Compose, the port and IDs will be passed as arguments.
# Default dummy values for standalone runs:
CMD ["python", "sandbox/worker.py", "--port", "9100", "--sandbox-id", "default", "--session-id", "default"]
